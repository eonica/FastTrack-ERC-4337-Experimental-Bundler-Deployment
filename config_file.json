{
  "name": "sensor",
  "verbose": true,
  "frequency": 500,
  "output": {
    "type": "csv",
    "directory": "/tmp/sensor_output/"
  },
  "system": {
    "rapl": {
      "events": ["RAPL_ENERGY_PKG","RAPL_ENERGY_DRAM"],
      "monitoring_type": "MONITOR_ONE_CPU_PER_SOCKET"
    },
    "msr": {
      "events": ["TSC", "APERF", "MPERF"]
    }
  },
  "container": {
    "core": {
      "events": [
        "LLC_MISSES",
        "INSTRUCTIONS_RETIRED"
      ]
    }
  }
}
